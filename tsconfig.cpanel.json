{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": false,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "noEmitOnError": false
    },
    "include": [
        "server.ts",
        "api/**/*.ts"
    ],
    "exclude": [
        "shinobij.client",
        "dist",
        "scripts",
        "node_modules",
        ".vs",
        "api/clan/war/_card-catalog.test.ts",
        "api/_jutsu-points-parity.test.ts",
        "api/_training-parity.test.ts"
    ]
}
