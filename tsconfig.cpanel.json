{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "./dist",
        "rootDir": ".",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": false,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true
    },
    "include": [
        "server.ts",
        "api/**/*.ts"
    ],
    "exclude": [
        "shinobij.client",
        "dist",
        "scripts",
        "node_modules",
        ".vs"
    ]
}
