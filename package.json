{
    "name": "shinobix-api",
    "version": "1.0.0",
    "private": true,
    "description": "ShinobiX game API — Express/cPanel backend, Supabase storage",
    "scripts": {
        "build:server": "tsc -p tsconfig.cpanel.json",
        "build:client": "cd shinobij.client && npm run build",
        "build": "npm run build:server && npm run build:client",
        "build:cpanel": "npm run build",
        "start": "node app.js",
        "dev": "node --watch app.js",
        "slice-badges": "node scripts/slice-badges.mjs",
        "test": "node --import tsx --test api/missions/_pool.test.ts api/pvp/_vanguard-rewards.test.ts api/_text-moderation.test.ts api/_utils.test.ts shinobij.client/src/professionLogic.test.ts"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.106.1",
        "@vercel/node": "^5.0.0",
        "dotenv": "^17.0.0",
        "express": "^5.0.1",
        "pg": "^8.21.0",
        "undici": "^6.0.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.0",
        "@types/node": "^22.0.0",
        "@types/pg": "^8.11.0",
        "ioredis": "^5.10.1",
        "sharp": "^0.34.5",
        "tsx": "^4.22.3",
        "typescript": "^5.7.0"
    }
}
